# ── Required ────────────────────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here

# ── Channel (optional) ───────────────────────────────────────────────────────
CHANNEL_URL=https://t.me/yourchannel      # shown in /help and welcome message
CHANNEL_ID=@yourchannel                   # used for daily hadith posts
DONATE_URL=https://t.me/yourchannel/123   # link shown in donate menu

# ── Admin ────────────────────────────────────────────────────────────────────
ADMIN_IDS=123456789                       # comma-separated Telegram user IDs

# ── Daily hadith (0 = disable) ───────────────────────────────────────────────
DAILY_HADITH_COUNT=3                      # sends are auto-distributed across 24h UTC
